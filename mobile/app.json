{
  "expo": {
    "name": "PharmFarm",
    "slug": "pharmfarm-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#eef1ed"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kr.pharmfarm.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "의약품 QR 및 바코드를 촬영해 입고와 반품 내역을 확인합니다.",
        "UIStatusBarHidden": true,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "android": {
      "package": "kr.pharmfarm.mobile",
      "permissions": ["CAMERA"]
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#ffffff"
    },
    "web": {
      "bundler": "metro"
    }
  }
}

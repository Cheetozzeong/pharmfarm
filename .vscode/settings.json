{
  "java.compile.nullAnalysis.mode": "automatic",
  "java.import.exclusions": [
    "**/node_modules/**"
  ],
  "java.project.resourceFilters": [
    "node_modules",
    ".git"
  ],
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/node_modules": true
  }
}
